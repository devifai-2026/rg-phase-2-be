# Google Cloud Pub/Sub — background-job fan-out (topics+subs live in project
# rudraganga; reuses GCS_PROJECT_ID + GCS_KEY_FILE for auth). When off, the
# Mongo job queue handles the same jobs.
PUBSUB_ENABLED=true
GEONAMES_USERNAME=subho98

# Firebase Admin (FCM push). Path to the service-account JSON (git-ignored).
