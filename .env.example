# ─────────────────────────────────────────────────────────────
# Super Astrology & Wellness Platform — environment
# Copy to .env and fill in. Anything left blank runs in MOCK mode
# (the app still boots and flows are testable without credentials).
# ─────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=5000
# INSTANCE_ID=  # auto = hostname:pid

# ── Database (replica set / Atlas required for MONGO_TX_ENABLED) ──
MONGO_URI=mongodb://127.0.0.1:27017/astro_wellness
MONGO_TX_ENABLED=false

# ── JWT ──
JWT_SECRET=change_me_to_a_long_random_string
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# ── WhatsApp OTP via WABridge (self-hosted HTTP bridge) ──
WABRIDGE_BASE_URL=https://web.wabridge.com/api
WABRIDGE_APP_KEY=
WABRIDGE_AUTH_KEY=
WABRIDGE_DEVICE_ID=
# In development a fixed OTP is used and WhatsApp is not actually sent:
OTP_DEV_CODE=123456
OTP_TTL_SEC=600
OTP_RESEND_COOLDOWN_SEC=30
OTP_MAX_SENDS_PER_HOUR=5
OTP_MAX_VERIFY_ATTEMPTS=5

# ── Agora (RTC tokens + cloud recording) ──
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=
AGORA_TOKEN_TTL_SEC=3600
AGORA_CUSTOMER_ID=
AGORA_CUSTOMER_SECRET=
AGORA_REC_BUCKET=
AGORA_REC_VENDOR=1
AGORA_REC_REGION=0
AGORA_REC_ACCESS_KEY=
AGORA_REC_SECRET_KEY=

# ── Firebase Cloud Messaging ──
# Path to service-account .json, raw JSON, or base64-encoded JSON.
FIREBASE_SERVICE_ACCOUNT_JSON=

# ── OpenAI (AI astrologer) ──
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_HISTORY_TURNS=12
OPENAI_MAX_TOKENS=700

# ── PayU Checkout (collections) ──
PAYU_KEY=
PAYU_SALT=
PAYU_BASE_URL=https://test.payu.in
PAYU_SURL=http://localhost:5000/api/payments/payu/callback
PAYU_FURL=http://localhost:5000/api/payments/payu/callback

# ── PayU Payout (settlements) ──
PAYU_PAYOUT_BASE_URL=https://uatoneapi.payu.in
PAYU_PAYOUT_CLIENT_ID=
PAYU_PAYOUT_CLIENT_SECRET=
PAYU_PAYOUT_ACCOUNT_ID=

# ── ImageBB (legacy image host; used only if GCS is not configured) ──
IMAGEBB_API_KEY=

# ── Google Cloud Storage (primary image host) ──
# Project + bucket you created in GCP.
GCS_PROJECT_ID=rudraganga
GCS_BUCKET=rudraganga
# Auth: set ONE of the two below.
#  - GCS_KEY_FILE: absolute path to a service-account JSON key file (local dev).
#  - GCS_CREDENTIALS_JSON: the key JSON as a single-line string (deploys / CI).
GCS_KEY_FILE=
GCS_CREDENTIALS_JSON=
# Folder inside the bucket for uploads (recordings can use a different prefix).
GCS_UPLOAD_PREFIX=uploads

# ── VedicAstroAPI ──
VEDIC_ASTRO_API_KEY=
VEDIC_ASTRO_BASE_URL=https://api.vedicastroapi.com/v3-json
VEDIC_CACHE_TTL_DAYS=365

# ── Socket.io scaling ──
# redis (scales across instances; point at GCP Memorystore) | mongo (Redis-free, uses Atlas) | memory (single instance/dev)
# If 'redis' is set but Redis is unreachable, the server logs a warning and falls back to memory.
# LOCAL DEV: keep 'memory' (Memorystore's private IP isn't reachable from your laptop).
# CLOUD RUN: set 'redis' + the Memorystore host below (requires a Serverless VPC connector).
SOCKET_ADAPTER=memory
REDIS_URL=redis://10.79.54.219:6379
SOCKET_PING_INTERVAL=25000
SOCKET_PING_TIMEOUT=20000
MAX_SOCKETS_PER_USER=5

# ── Cache (GCP Memorystore for Redis) ──
# Cache-aside for hot reads (astrologer list/profile/rates/app-config) + the
# online-astrologer set. Disabled by default; the server falls through to direct
# Mongo reads when off/unreachable. Reuses REDIS_URL if CACHE_REDIS_URL is unset.
# Enable only where the Memorystore IP is reachable (Cloud Run + VPC connector).
CACHE_ENABLED=false
CACHE_REDIS_URL=redis://10.79.54.219:6379
CACHE_DEFAULT_TTL_SEC=60
CACHE_KEY_PREFIX=rg

# ── Pub/Sub (decoupled background fan-out: payouts, FCM, recordings, translation) ──
# Billing (bill_tick) + ring_timeout NEVER use Pub/Sub — they stay on the Mongo
# timer queue (precise scheduling). When PUBSUB_ENABLED=false (or publish fails)
# producers fall back to the Mongo job queue, so nothing breaks.
# Auth reuses the GCS service-account key by default (same rudraganga project).
# Topics/subs provisioned: rg-{payouts,notifications,recordings,translation} (+ rg-deadletter).
PUBSUB_ENABLED=false
PUBSUB_PROJECT_ID=rudraganga
PUBSUB_KEY_FILE=
PUBSUB_CREDENTIALS_JSON=
PUBSUB_TOPIC_PREFIX=rg

# ── Jobs ──
JOB_POLL_INTERVAL_MS=2000
JOB_STALE_SWEEP_MS=60000
JOB_STALE_MS=120000
JOB_MAX_ATTEMPTS=5

# ── Internal jobs (Cloud Scheduler → /api/internal/jobs/*) ──
# Shared secret Cloud Scheduler sends as the X-Internal-Secret header. Required
# in production; if empty in dev the internal endpoints are open on localhost.
INTERNAL_JOB_SECRET=

# ── BigQuery (cheap append-only store for logs/analytics/notification events) ──
# High-volume, analyze-later data lives here instead of MongoDB. Disabled by
# default → writers no-op (nothing breaks locally). Auth reuses the GCS key.
# Dataset rg_analytics has tables: api_logs, analytics_events, notification_events.
BQ_ENABLED=false
BQ_PROJECT_ID=rudraganga
BQ_DATASET=rg_analytics
BQ_KEY_FILE=
BQ_CREDENTIALS_JSON=
BQ_FLUSH_INTERVAL_MS=5000
BQ_MAX_BUFFER=500

# ── Admin-tunable settings live in the database, not here ──
# The withdrawal threshold, escalation thresholds, signup bonus, gift token
# rate, ring timeout (60s) and max call minutes are stored in the AdminSettings
# collection and changed at runtime via PUT /api/admin/settings.
# The platform commission is per-astrologer (absolute ₹/min adminCutPerMin),
# not a global percentage.

# ── GeoNames (free place-of-birth search; create username at geonames.org) ──
GEONAMES_USERNAME=
